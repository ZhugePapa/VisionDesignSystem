{
  "extends": "./tsconfig.app.json",
  "include": ["src/**/*.ts", "src/**/*.vue"],
  "exclude": ["src/App.vue", "src/main.ts"],
  "compilerOptions": {
    "composite": false,
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "rootDir": "src",
    "outDir": "dist/types"
  }
}
